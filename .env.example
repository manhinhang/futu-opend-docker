FUTU_ACCOUNT_ID=
# Compute with: echo -n '<your-password>' | md5sum | awk '{print $1}'
FUTU_ACCOUNT_PWD_MD5=
# FUTU_ACCOUNT_PWD=  # deprecated; legacy fallback hashed at runtime by start.sh
# Bind address inside the container. Keep 127.0.0.1 unless you must expose
# OpenD beyond loopback — 0.0.0.0 listens on every interface (security risk).
FUTU_OPEND_IP=127.0.0.1
FUTU_OPEND_RSA_FILE_PATH=/.futu/futu.pem
LOCAL_RSA_FILE_PATH=./futu.pem
# Mirrors stableVersion in opend_version.json. Update both when bumping.
FUTU_OPEND_VER=10.7.6728
